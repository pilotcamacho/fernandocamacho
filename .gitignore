# but the real file is overwritten at build time.
# amplify_outputs.json  ← intentionally NOT gitignored (placeholder committed)

# Amplify compiled outputs — generated by postinstall esbuild
amplify/**/*.mjs

# Amplify sandbox state
.amplify/

