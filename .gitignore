# Dependencies
node_modules/
.pnp
.pnp.js

# Next.js
.next/
out/
build/

# Environment variables — never commit secrets
.env
.env.*
.env.local
.env.development.local
.env.test.local
.env.production.local

# Amplify outputs — auto-generated by `npx ampx sandbox` (local)
